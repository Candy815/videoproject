# ========================
# 视频抄袭检测系统环境配置
# ========================
# 复制此文件为 .env 并根据实际环境进行配置
# 注意：请勿提交包含敏感信息的 .env 文件到版本控制

# ============ Milvus 数据库配置 ============
# Milvus 服务器主机地址
MILVUS_HOST=localhost

# Milvus 服务器端口
MILVUS_PORT=19530

# ============ 大模型配置 ============
# 选择大模型提供商: ollama 或 openai
LLM_PROVIDER=ollama

# ----- Ollama 配置 -----
# Ollama API 基础地址
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 模型名称
OLLAMA_MODEL=qwen2.5:7b

# ----- OpenAI 配置 -----
# OpenAI API 密钥（仅在 LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API 基础地址（可选，默认为官方地址）
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型名称
OPENAI_MODEL=gpt-3.5-turbo

# ============ 高级配置（可选） ============
# 代理服务器配置（如需通过代理访问外部服务）
HTTP_PROXY=http://proxy.example.com:8080
HTTPS_PROXY=http://proxy.example.com:8080

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============ 注意事项 ============
# 1. 确保 Milvus 数据库已正确安装并运行
# 2. 如果使用 Ollama，确保已安装并启动 Ollama 服务
# 3. 如果使用 OpenAI，需要有效的 API 密钥
# 4. 所有配置项都可以在 config/settings.py 中被覆盖